# ─────────────────────────────────────────────────────────────
# INNOVATECH SOLUTIONS GLOBAL S.A.S — Variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# Las variables NEXT_PUBLIC_* se exponen al navegador (necesario para EmailJS).
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (usada por sitemap, robots, canonical y Open Graph)
# Dominio Production en Vercel = www (el apex redirige aquí con 307).
NEXT_PUBLIC_SITE_URL=https://www.innovatechsolutions.lat

# ── EmailJS (https://dashboard.emailjs.com) ──
# Service ID del servicio de correo conectado en EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# Template que envía la notificación interna al equipo (contacto@innovatechsolutions.lat)
NEXT_PUBLIC_EMAILJS_TEMPLATE_NOTIFICACION=
# Template de auto-respuesta que se envía al visitante
NEXT_PUBLIC_EMAILJS_TEMPLATE_AUTORESPUESTA=
# Public Key (API key pública) de tu cuenta de EmailJS
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# (Opcional) Verificación de Google Search Console — código del meta tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
